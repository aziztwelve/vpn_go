# ============================================================
# VPN STACK — MASTER CONFIGURATION
# ============================================================
# Этот файл содержит ВСЕ переменные для ВСЕХ сервисов.
# Используются префиксы (AUTH_*, SUB_*, VPN_*, GATEWAY_*) чтобы
# избежать конфликтов. Per-service .env генерируются из этого
# мастера через `task env:generate` (see generate-env.sh).
# ============================================================

# ------------------------------------------------------------
# CORE INFRASTRUCTURE
# ------------------------------------------------------------

# PostgreSQL (на старте — один общий юзер/БД/public-схема)
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vpn
POSTGRES_USER=vpn
POSTGRES_PASSWORD=change_me_strong_password

# Хост-порт (что биндится на хост машине). Если 5432 занят другим
# postgres, поменяй на 5433/5434/…
POSTGRES_HOST_PORT=5433

# Для локального запуска сервисов на хосте (task dev:*) postgres
# не в docker-сети, а на localhost:POSTGRES_HOST_PORT
POSTGRES_HOST_LOCAL=localhost

# ------------------------------------------------------------
# AUTH SERVICE (50060)
# ------------------------------------------------------------
AUTH_GRPC_HOST=0.0.0.0
AUTH_GRPC_PORT=50060

AUTH_LOG_LEVEL=info

AUTH_JWT_SECRET=change_me_to_long_random_string_min_32_chars
AUTH_JWT_TTL_HOURS=168

# Get from @BotFather → /newbot
AUTH_TELEGRAM_BOT_TOKEN=8511824444:AAFCtnMjG1n_mfv2OsXgAvHQtddWxp9Lnf4

# ------------------------------------------------------------
# SUBSCRIPTION SERVICE (50061)
# ------------------------------------------------------------
SUB_GRPC_HOST=0.0.0.0
SUB_GRPC_PORT=50061
SUB_LOG_LEVEL=info

# ------------------------------------------------------------
# VPN SERVICE (50062) + XRAY (Reality)
# ------------------------------------------------------------
VPN_GRPC_HOST=0.0.0.0
VPN_GRPC_PORT=50062
VPN_LOG_LEVEL=info

# Xray в docker-сети vpn-stack_vpn. Для dev — локальный контейнер xray.
VPN_XRAY_API_HOST=xray
VPN_XRAY_API_PORT=10085
# Порт VLESS — тот же и в контейнере, и на хосте. На проде обычно 443,
# на dev 8443 т.к. 443 часто занят другим процессом.
VPN_XRAY_VLESS_PORT=8443
VPN_XRAY_INBOUND_TAG=vless-reality-in

# Reality keys (dev-значения; для prod генерируй свои через `docker run --rm
# ghcr.io/xtls/xray-core:latest x25519` и `openssl rand -hex 8`).
VPN_XRAY_REALITY_PRIVATE_KEY=6D09lBpdHArN-hKskES_f9PeCUp98TZfT84rH41cTWg
VPN_XRAY_REALITY_PUBLIC_KEY=38lbFSvv_h0qf4BGg3AQTckKT0zq_QCiuf7HMFkiTW8
VPN_XRAY_REALITY_SHORT_ID=a7c1226d7c93e272
VPN_XRAY_REALITY_DEST=github.com:443
VPN_XRAY_REALITY_SNI=github.com

# Публичный хост VLESS-сервера (что показывается клиенту в ссылке).
# Для локальной разработки — localhost (с телефона не подключиться,
# используй локальный xray-client). На VPS поставь реальный домен/IP.
VPN_XRAY_PUBLIC_HOST=localhost

# ------------------------------------------------------------
# PAYMENT SERVICE (50063) — Telegram Stars (этап 5)
# ------------------------------------------------------------
PAYMENT_GRPC_HOST=0.0.0.0
PAYMENT_GRPC_PORT=50063
PAYMENT_LOG_LEVEL=info

# Shared secret для валидации webhook'а от Telegram.
# Отдаётся в setWebhook как `secret_token`, потом проверяется в
# заголовке X-Telegram-Bot-Api-Secret-Token. Защищает от фальшивых
# webhook'ов.
PAYMENT_TELEGRAM_WEBHOOK_SECRET=change_me_random_string_webhook_secret

# ------------------------------------------------------------
# REFERRAL SERVICE (50064) — резерв под этап 7
# ------------------------------------------------------------
REFERRAL_GRPC_HOST=0.0.0.0
REFERRAL_GRPC_PORT=50064
REFERRAL_LOG_LEVEL=info

# ------------------------------------------------------------
# ADMIN SERVICE (50065) — резерв под этап 8
# ------------------------------------------------------------
ADMIN_GRPC_HOST=0.0.0.0
ADMIN_GRPC_PORT=50065
ADMIN_LOG_LEVEL=info

# ------------------------------------------------------------
# API GATEWAY (HTTP 8081)
# ------------------------------------------------------------
GATEWAY_HTTP_HOST=0.0.0.0
GATEWAY_HTTP_PORT=8081
GATEWAY_LOG_LEVEL=info

# Адреса апстримов (имена из docker-сети для compose; для host-dev
# берутся из per-service шаблона с localhost:<port>)
GATEWAY_AUTH_SERVICE_ADDR=auth-service:50060
GATEWAY_SUB_SERVICE_ADDR=subscription-service:50061
GATEWAY_VPN_SERVICE_ADDR=vpn-service:50062
GATEWAY_PAYMENT_SERVICE_ADDR=payment-service:50063
GATEWAY_REFERRAL_SERVICE_ADDR=referral-service:50064
GATEWAY_ADMIN_SERVICE_ADDR=admin-service:50065

# ------------------------------------------------------------
# PUBLIC HTTPS EDGE (Caddy auto-TLS) — prod-only profile
# ------------------------------------------------------------
# Домен, на который указывает A-запись VPS. Смена = правка этой
# строки + `task domain:swap` (Caddy автоматом выпустит новый серт).
API_DOMAIN=api.osmonai.com

# Домен для Telegram Mini App (vpn_next). Отдельная A-запись на VPS.
# Caddy проксирует cdn.osmonai.com → vpn-next:3000 (Next.js standalone).
CDN_DOMAIN=cdn.osmonai.com

# Email для Let's Encrypt-уведомлений об истечении сертификата.
ACME_EMAIL=admin@osmonai.com

# ------------------------------------------------------------
# FRONTEND (vpn_next)
# ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8081
