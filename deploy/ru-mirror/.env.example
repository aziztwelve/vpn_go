# Скопируй в .env и подставь реальные значения.

# Публичный домен зеркала. В CF — A-запись на IP RU-VPS, ☁️ DNS only.
RU_DOMAIN=s.osmonai.com

# Email для Let's Encrypt (account, не reply-to).
ACME_EMAIL=admin@osmonai.com

# IP FI-стороны WG-туннеля + порт gateway. Менять не надо если
# WireGuard-конфиг создан по дефолту из deploy/ru-mirror/wireguard.md.
GATEWAY_UPSTREAM=10.13.13.1:8081
