# Binaries
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary
*.test

# Output of the go coverage tool
*.out

# Dependency directories
vendor/

# Go workspace file
go.work.sum

# Environment files
.env
*.env
!*.env.template

# Backup files (from sed -i.bak, etc.)
*.bak

# Generated Xray config (from config.json.template)
deploy/compose/xray/config.json

# Per-server Xray configs созданные deploy-xray-new.sh — содержат
# приватные Reality keys, не должны попадать в git.
deploy/compose/xray-new/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
logs/*.log
*.log

# Proto generated files
shared/pkg/proto/

# Build artifacts
tmp/

# Go-service бинари локальной сборки (матчим только
# services/<name>/<name>, чтобы пакеты с Go-исходниками не зацепить).
services/*/auth-service
services/*/payment-service
services/*/subscription-service
services/*/vpn-service
services/*/gateway
